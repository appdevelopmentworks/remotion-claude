# 依存パッケージ（npm install で再生成できるので除外）
node_modules/

# 書き出した動画ファイル（容量が大きいので除外）
out/

# OS が自動生成するファイル
.DS_Store
Thumbs.db
Desktop.ini

# エディタの設定ファイル
.vscode/
.idea/
*.swp
*.swo

# TypeScript ビルドキャッシュ
*.tsbuildinfo

# 環境変数ファイル（APIキーなど秘密情報を含む場合）
.env
.env.local
.env.*.local

# Remotion のキャッシュ
.remotion/

# ログファイル
npm-debug.log*
yarn-debug.log*
yarn-error.log*
