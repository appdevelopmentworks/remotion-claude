# ─── 依存パッケージ ───────────────────────────────────────────────
# npm install で再生成できるので除外
node_modules/

# ─── 書き出し動画 ─────────────────────────────────────────────────
# 容量が大きいので除外（npx remotion render で再生成可能）
out/

# ─── 素材ファイル（サイズが大きいため除外）──────────────────────────
# 音声: VOICEVOX WAV（再生成可能）、BGM・効果音 MP3 など
public/audio/
# 写真・画像素材
public/photos/
# 動画素材
public/videos/

# ─── Remotion キャッシュ ──────────────────────────────────────────
.remotion/

# ─── OS 自動生成ファイル ──────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# ─── エディタ設定 ─────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ─── TypeScript ──────────────────────────────────────────────────
*.tsbuildinfo

# ─── 環境変数（APIキーなど秘密情報）──────────────────────────────
.env
.env.local
.env.*.local

# ─── ログ ─────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
